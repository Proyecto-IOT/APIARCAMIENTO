<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.MainActivity"
    android:paddingStart="55dp"
    android:paddingEnd="55dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@color/white">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/animationView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:lottie_rawRes="@raw/op2"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:layout_centerHorizontal="true"/>

    <!-- LOGO -->
    <TextView
        android:id="@+id/nom_app"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:fontFamily="@font/osval"
        android:text="@string/app_name"
        android:layout_below="@id/animationView"
        android:textSize="22dp"
        android:layout_centerHorizontal="true"
        android:lineSpacingExtra="2sp"
        />

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/nom_app">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- NOMBRE -->
            <TextView
                android:id="@+id/text_name"
                android:layout_marginTop="25dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="Nombre"
                android:textSize="16sp"
                android:lineSpacingExtra="2sp"
                />

            <EditText
                android:id="@+id/nameField"
                android:layout_width="342dp"
                android:layout_height="45dp"
                android:layout_below="@id/text_name"
                android:layout_centerHorizontal="true"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

            <!-- APELLIDOS -->
            <RelativeLayout
                android:id="@+id/contenedorApellidos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/nameField"
                android:layout_centerHorizontal="true">

                <TextView
                    android:id="@+id/text_lastname1"
                    android:layout_marginTop="25dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:text="Apellido paterno"
                    android:textSize="16sp"
                    android:lineSpacingExtra="2sp"
                    android:paddingEnd="40dp"
                    />

                <EditText
                    android:id="@+id/usernameField"
                    android:layout_width="120dp"
                    android:layout_height="45dp"
                    android:layout_marginEnd="36dp"
                    android:layout_below="@id/text_lastname1"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

                <TextView
                    android:id="@+id/text_lastname2"
                    android:layout_marginTop="25dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:text="Apellido materno"
                    android:layout_toEndOf="@id/text_lastname1"
                    android:textSize="16sp"
                    android:lineSpacingExtra="2sp"
                    />

                <EditText
                    android:id="@+id/MSurnameField"
                    android:layout_width="120dp"
                    android:layout_height="45dp"
                    android:layout_toEndOf="@id/usernameField"
                    android:layout_below="@id/text_lastname2"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />


            </RelativeLayout>

            <!-- EMAIL -->
            <TextView
                android:id="@+id/text_email"
                android:layout_marginTop="25dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="Email"
                android:layout_below="@id/contenedorApellidos"
                android:textSize="16sp"
                android:lineSpacingExtra="2sp"
                />

            <EditText
                android:id="@+id/emailField"
                android:layout_width="342dp"
                android:layout_height="45dp"
                android:layout_below="@id/text_email"
                android:layout_centerHorizontal="true"
                android:inputType="textEmailAddress"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

            <!-- PASSWORD -->
            <TextView
                android:id="@+id/text_password"
                android:layout_marginTop="25dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="password"
                android:layout_below="@id/emailField"
                android:textSize="16sp"
                android:lineSpacingExtra="2sp"
                />

            <EditText
                android:id="@+id/passwordField"
                android:layout_width="342dp"
                android:layout_height="45dp"
                android:layout_below="@id/text_password"
                android:layout_centerHorizontal="true"
                android:inputType="textPassword"
                android:password="true"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        </RelativeLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_login"
        android:textStyle="bold"
        style="@style/Widget.Material3.Button.ElevatedButton"
        android:layout_width="300dp"
        android:layout_height="48dp"
        android:layout_below="@id/scroll"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:text="Sign Up"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/textNoCuenta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:text="👉 IoTengo cuenta 👈"
        android:textSize="22sp"
        android:layout_below="@id/btn_login"
        android:layout_marginTop="66dp"
        android:layout_centerHorizontal="true"
        />

    <TextView
        android:id="@+id/textCredits"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="©Creado por Jose, Fernando, Erick, Jonathan y Lizeth ❤"
        android:textSize="10sp"
        android:layout_marginBottom="10dp"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        />
</RelativeLayout>